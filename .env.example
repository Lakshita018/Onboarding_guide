# Server Configuration
PORT=5000
NODE_ENV=development

# Database Settings
# For PostgreSQL: postgresql://username:password@localhost:5432/ibm_onboard_ai
# For SQLite: sqlite://database.sqlite
DATABASE_URL=sqlite://database.sqlite

# Security
JWT_SECRET=your_jwt_secret_key_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# IBM Watson Services
WATSONX_API_KEY=your_ibm_watsonx_api_key_here
WATSONX_PROJECT_ID=your_ibm_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
ASSISTANT_ID=your_watsonx_assistant_id_here

# Storage
UPLOAD_PATH=uploads/
