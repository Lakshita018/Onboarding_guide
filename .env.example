# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Firebase Admin SDK (server/config/firebase.js) ────────────────────────────
# Option A: Inline service account JSON (CI/production)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B: Path to service account file
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option C: Individual env vars (recommended for local dev)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Cloudinary (server/config/cloudinary.js) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── IBM Watson Services (stubbed) ─────────────────────────────────────────────
WATSONX_API_KEY=your_ibm_watsonx_api_key_here
WATSONX_PROJECT_ID=your_ibm_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
ASSISTANT_ID=your_watsonx_assistant_id_here

# ── Client env (save as client/.env) ──────────────────────────────────────────
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000
# VITE_FIREBASE_API_KEY=your_firebase_web_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
